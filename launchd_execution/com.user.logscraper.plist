<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Identificador único del servicio -->
	<key>Label</key>
	<string>com.user.logscraper</string>

	<!-- MIGRADO: ya NO usa APScheduler ni scheduler/scheduler_main.py.
	     Ahora levanta el stack Celery + Redis via Docker Compose.
	     NOTA: Docker Desktop debe estar corriendo para que este comando funcione.
	     Si prefieres control manual, desactiva este plist y usa:
	       cd .../scrapping_project/scheduler_celery && docker compose up -d --build -->
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/docker</string>
		<string>compose</string>
		<string>-f</string>
		<string>/Users/administrator/Desktop/scrapping_project/scheduler_celery/docker-compose.yml</string>
		<string>up</string>
		<string>--build</string>
	</array>

	<!-- Directorio de trabajo (importante para rutas relativas) -->
	<key>WorkingDirectory</key>
	<string>/Users/administrator/Desktop/scrapping_project</string>

	<!-- Variables de entorno necesarias -->
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>

	<!-- RunAtLoad desactivado: Docker Desktop puede no estar listo al boot.
	     Para arranque automático, usa un Login Item de Docker Desktop
	     y luego actívalo de nuevo poniendo <true/> -->
	<key>RunAtLoad</key>
	<false/>

	<!-- Mantener el proceso siempre activo (reiniciar si falla) -->
	<key>KeepAlive</key>
	<true/>

	<!-- Logging: Salida estándar -->
	<key>StandardOutPath</key>
	<string>/Users/administrator/Desktop/scrapping_project/launchd_execution/logs/stdout.log</string>

	<!-- Logging: Errores -->
	<key>StandardErrorPath</key>
	<string>/Users/administrator/Desktop/scrapping_project/launchd_execution/logs/stderr.log</string>

	<!-- Tiempo de espera antes de reiniciar tras un fallo (segundos) -->
	<key>ThrottleInterval</key>
	<integer>30</integer>
</dict>
</plist>
